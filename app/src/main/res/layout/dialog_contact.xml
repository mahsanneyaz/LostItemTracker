<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contact Information"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/manrope"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="20dp"/>

    <!-- Name row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NAME"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/outline"
        android:letterSpacing="0.12"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvContactName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="@color/on_surface"/>
        <ImageView
            android:id="@+id/ivCopyName"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_copy"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Email row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMAIL"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/outline"
        android:letterSpacing="0.12"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvContactEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="@color/on_surface"/>
        <ImageView
            android:id="@+id/ivCopyEmail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_copy"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Phone row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PHONE"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/outline"
        android:letterSpacing="0.12"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        <TextView
            android:id="@+id/tvContactPhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="@color/on_surface"/>
        <ImageView
            android:id="@+id/ivCopyPhone"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_copy"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Open Email App button -->
    <Button
        android:id="@+id/btnOpenEmailApp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Open Email App  →"
        android:textColor="@color/btn_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnCloseContact"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Close"
        android:textSize="14sp"
        android:textColor="@color/outline"
        android:backgroundTint="@color/surface_container_high"
        android:stateListAnimator="@null"/>

</LinearLayout>