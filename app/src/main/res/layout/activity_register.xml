<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <Space android:layout_width="0dp" android:layout_height="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lost Item Tracker"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope"
            android:textColor="@color/primary"
            android:layout_marginBottom="4dp"/>

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textSize="18sp"
                    android:fontFamily="@font/manrope"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="20dp"/>

                <!-- Full Name -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FULL NAME" android:textSize="10sp" android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/input_bg" android:layout_marginBottom="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_person" android:layout_marginStart="14dp"
                        android:layout_marginEnd="10dp" android:alpha="0.5"/>
                    <EditText android:id="@+id/etName" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:background="@null"
                        android:hint=" Name " android:textColorHint="@color/outline"
                        android:inputType="textPersonName" android:textColor="@color/on_surface" android:textSize="15sp"/>
                </LinearLayout>

                <!-- Email -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="EMAIL" android:textSize="10sp" android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/input_bg" android:layout_marginBottom="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_mail" android:layout_marginStart="14dp"
                        android:layout_marginEnd="10dp" android:alpha="0.5"/>
                    <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:background="@null"
                        android:hint="name@mail.com" android:textColorHint="@color/outline"
                        android:inputType="textEmailAddress" android:textColor="@color/on_surface" android:textSize="15sp"/>
                </LinearLayout>

                <!-- Password -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PASSWORD" android:textSize="10sp" android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/input_bg" android:layout_marginBottom="16dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_lock" android:layout_marginStart="14dp"
                        android:layout_marginEnd="10dp" android:alpha="0.5"/>
                    <EditText android:id="@+id/etPassword" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:background="@null"
                        android:hint="Min. 6 characters" android:textColorHint="@color/outline"
                        android:inputType="textPassword" android:textColor="@color/on_surface" android:textSize="15sp"/>
                </LinearLayout>

                <!-- Confirm Password — NEW -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONFIRM PASSWORD" android:textSize="10sp" android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.12" android:textStyle="bold" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/input_bg" android:layout_marginBottom="28dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_lock" android:layout_marginStart="14dp"
                        android:layout_marginEnd="10dp" android:alpha="0.5"/>
                    <EditText android:id="@+id/etConfirmPassword" android:layout_width="match_parent"
                        android:layout_height="match_parent" android:background="@null"
                        android:hint="Re-enter password" android:textColorHint="@color/outline"
                        android:inputType="textPassword" android:textColor="@color/on_surface" android:textSize="15sp"/>
                </LinearLayout>

                <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center"
                    android:layout_marginBottom="12dp" android:visibility="gone"/>

                <Button android:id="@+id/btnRegister" android:layout_width="match_parent"
                    android:layout_height="54dp" android:text="Register  →"
                    android:textColor="@color/btn_text" android:textSize="16sp" android:textStyle="bold"
                    android:fontFamily="@font/manrope" android:background="@drawable/btn_primary"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView android:id="@+id/tvGoToLogin" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Already have an account?  Login"
            android:textColor="@color/secondary" android:textSize="14sp"
            android:textStyle="bold" android:padding="8dp"/>

    </LinearLayout>
</ScrollView>