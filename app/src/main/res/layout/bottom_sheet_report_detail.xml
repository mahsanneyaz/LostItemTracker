<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/bsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Report Details"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/manrope"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/bsPhoto"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:background="@color/surface_container"
        android:src="@android:drawable/ic_menu_gallery"
        android:layout_marginBottom="14dp"/>

    <TextView android:id="@+id/bsItemName"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="6dp"
        android:textColor="@color/on_surface"/>

    <TextView android:id="@+id/bsCategory"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="6dp"
        android:textColor="@color/on_surface"/>

    <TextView android:id="@+id/bsDescription"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="6dp"
        android:textColor="@color/on_surface"/>

    <TextView android:id="@+id/bsLocation"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="6dp"
        android:textColor="@color/on_surface"/>

    <TextView android:id="@+id/bsDate"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="6dp"
        android:textColor="@color/on_surface"/>

    <TextView android:id="@+id/bsStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="20dp"
        android:textColor="@color/on_surface"/>

    <!-- QR Code button -->
    <Button
        android:id="@+id/bsBtnQR"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Show QR Code"
        android:textColor="@color/btn_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp"/>

    <!-- Delete button -->
    <Button
        android:id="@+id/bsBtnDelete"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Delete This Report"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/error"/>

</LinearLayout>