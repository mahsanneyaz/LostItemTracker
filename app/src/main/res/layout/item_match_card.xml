<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_container_lowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Score badge -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="85% Match"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@color/tertiary"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- Lost item -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOST ITEM"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/error"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"/>
        <TextView
            android:id="@+id/tvLostItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp"/>

        <!-- Found item -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOUND ITEM"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/tertiary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"/>
        <TextView
            android:id="@+id/tvFoundItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="16dp"/>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_container"
            android:layout_marginBottom="12dp"/>

        <!-- Contact button — always visible -->
        <Button
            android:id="@+id/btnContact"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Contact  →"
            android:textColor="@color/btn_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <!-- Confirm + Reject buttons — only shown when status is "pending" -->
        <LinearLayout
            android:id="@+id/llMatchActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfirmMatch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Confirm ✓"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/tertiary"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnRejectMatch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Reject ✗"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/error"
                android:backgroundTint="@color/surface_container_high"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Status label — shown when match is already confirmed or rejected -->
        <TextView
            android:id="@+id/tvMatchStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>